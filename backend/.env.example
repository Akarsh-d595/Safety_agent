# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Server ─────────────────────────────────────────────────────────────────────
# 0.0.0.0 makes the backend reachable from any device on your LAN
HOST=0.0.0.0
PORT=8000

# ── Twilio (SMS alerts) ────────────────────────────────────────────────────────
# Leave blank to skip SMS — the app still works without it
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
# Must be strict E.164 — no spaces or parentheses: +17433477403
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ── Emergency contacts fallback ────────────────────────────────────────────────
# Comma-separated E.164 numbers used when the app sends no contacts list
EMERGENCY_CONTACTS=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Use * for development. In production restrict to your domain:
# ALLOWED_ORIGINS=https://yourdomain.com
ALLOWED_ORIGINS=*

# ── Storage ────────────────────────────────────────────────────────────────────
INCIDENT_STORE_FILE=incidents.json
CONTACT_STORE_FILE=contacts.json
